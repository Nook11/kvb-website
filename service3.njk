            <div class="row g-5">
                <div class="col-lg-7">
                    <h3 class="fw-bold mb-3 text-primary">{{ card_title }}</h3>
                    <div class="mt-4">
                        <h5 class="fw-bold">{{ objectives_title }}</h5>
                        <ul class="list-unstyled">
                            {% for item in objectives_list %}
